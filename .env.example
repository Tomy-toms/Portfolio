# --- Database (Postgres via Supabase, Neon, Railway, or local) ---
# Example (Supabase): postgresql://postgres:[PASSWORD]@db.[PROJECT].supabase.co:5432/postgres
DATABASE_URL="postgresql://user:password@localhost:5432/portfolio?schema=public"

# --- Auth ---
# Generate with: openssl rand -base64 48
JWT_SECRET="replace-me-with-a-long-random-string-at-least-48-chars"

# Seed admin credentials (only used by `npm run db:seed`)
ADMIN_EMAIL="admin@example.com"
ADMIN_PASSWORD="change-me-in-production"

# --- Site ---
# Production: https://thomasbarthelemy.fr — use http://localhost:3000 for local dev
NEXT_PUBLIC_SITE_URL="https://thomasbarthelemy.fr"
NEXT_PUBLIC_SITE_NAME="Thomas Barthelemy — Développeur web à Alès"
NEXT_PUBLIC_CONTACT_EMAIL="hello@example.com"

# --- Email (Resend) ---
# https://resend.com → API Keys
# FROM: use onboarding@resend.dev until your domain is verified on Resend
RESEND_API_KEY=""
RESEND_FROM="Portfolio Contact <onboarding@resend.dev>"
